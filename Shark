<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ถึงคนพิเศษ ❤️</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:sans-serif;
    background:linear-gradient(135deg,#ff9a9e,#fad0c4);
    overflow:hidden;
    color:white;
}

#intro,#main{
    width:100%;
    height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
    padding:20px;
}

button{
    padding:12px 24px;
    border:none;
    border-radius:30px;
    font-size:18px;
    cursor:pointer;
    margin:10px;
}

.openBtn,#yes{
    background:#ff4d6d;
    color:white;
}

#no{
    background:white;
    color:black;
}

#loveLetter{
    max-width:700px;
    line-height:1.8;
    font-size:20px;
    margin:20px 0;
}

#result{
    margin-top:20px;
}

.heart{
    position:fixed;
    pointer-events:none;
}
</style>
</head>
<body>

<div id="intro">
    <h1>💌 มีอะไรจะบอก...</h1>
    <br>
    <button class="openBtn" onclick="startPage()">เปิดอ่านเลย ❤️</button>
</div>

<div id="main" style="display:none;">
    <h1>❤️ ถึงคนพิเศษของเค้า ❤️</h1>

    <p id="loveLetter"></p>

    <h2>เป็นแฟนกันต่อไหม? 🥺</h2>

    <div>
        <button id="yes" onclick="love()">เป็นสิ ❤️</button>
        <button id="no">ไม่เอา 😝</button>
    </div>

    <div id="result"></div>
</div>

<script>

const text =
"ถ้ามีคนถามว่าอะไรคือสิ่งที่ดีที่สุดที่เกิดขึ้นในชีวิต เค้าคงตอบได้ทันทีว่า... การได้เจอเธอ ❤️ ขอบคุณที่เข้ามาเป็นทั้งรอยยิ้ม ความสบายใจ และความสุขในทุกวันนะ อยู่เป็นคนพิเศษของเค้าไปนาน ๆ เลยนะ 🥺🌷";

function startPage(){

    document.getElementById('intro').style.display='none';
    document.getElementById('main').style.display='flex';

    let i=0;

    function typeWriter(){
        if(i < text.length){
            document.getElementById("loveLetter").innerHTML += text.charAt(i);
            i++;
            setTimeout(typeWriter,50);
        }
    }

    typeWriter();
}

function love(){

    document.getElementById("result").innerHTML =
    "<h2>เย้! งั้นสัญญาว่าจะรักเธอไปอีกนานเลย ❤️🥰</h2>";

    for(let i=0;i<100;i++){
        createHeart();
    }
}

function createHeart(){

    const heart=document.createElement("div");

    heart.className="heart";
    heart.innerHTML="❤️";

    heart.style.left="50%";
    heart.style.top="50%";
    heart.style.fontSize=(20+Math.random()*30)+"px";

    document.body.appendChild(heart);

    const x=(Math.random()-0.5)*1200;
    const y=(Math.random()-0.5)*1200;

    heart.animate([
        {
            transform:"translate(0,0)",
            opacity:1
        },
        {
            transform:`translate(${x}px,${y}px)`,
            opacity:0
        }
    ],{
        duration:2000
    });

    setTimeout(()=>{
        heart.remove();
    },2000);
}

const noBtn=document.getElementById("no");

noBtn.addEventListener("mouseover",()=>{

    noBtn.style.position="absolute";

    noBtn.style.left=
    Math.random()*(window.innerWidth-120)+"px";

    noBtn.style.top=
    Math.random()*(window.innerHeight-80)+"px";
});

</script>

</body>
</html>
